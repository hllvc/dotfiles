{
  "env": {
    "BASH_ENV": "/Users/hllvc/.local/bin/claude-shims-init.sh",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_ANALYTICS": "1",
    "CLAUDE_CODE_ENABLE_TASKS": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_HOOK_DEBUG": "0"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(find:*)",
      "Read(~/.repos/**)",
      "Glob(~/.repos/**)",
      "Grep(~/.repos/**)",
      "Bash(tree:*)",
      "Bash(tmux:*)",
      "Bash(aws:*)",
      "Bash(op plugin run -- aws:*)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Write(~/.ssh/**)",
      "Glob(~/.ssh/**)",
      "Grep(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Write(~/.aws/**)",
      "Glob(~/.aws/**)",
      "Grep(~/.aws/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Edit(~/.config/gh/hosts.yml)",
      "Write(~/.config/gh/hosts.yml)",
      "Glob(~/.config/gh/hosts.yml)",
      "Grep(~/.config/gh/hosts.yml)",
      "Read(~/.netrc)",
      "Edit(~/.netrc)",
      "Write(~/.netrc)",
      "Glob(~/.netrc)",
      "Grep(~/.netrc)"
    ],
    "ask": [],
    "defaultMode": "plan"
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/hllvc/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-plugins-official.git"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "gist.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "codeload.github.com",
        "registry.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "files.pythonhosted.org",
        "stackoverflow.com",
        "api.anthropic.com",
        "api.openai.com",
        "auth.openai.com",
        "registry.opentofu.org",
        "*.amazonaws.com",
        "*.1password.com"
      ]
    },
    "additionalDirectories": [
      "/Users/hllvc/.claude/plugins/data"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "tui": "default",
  "skipDangerousModePermissionPrompt": true,
  "preferredNotifChannel": "ghostty",
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
