<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hllvc.personal.tmux</string>
    <key>ProgramArguments</key>
    <!-- Staggered behind com.hllvc.work.tmux: both warm at login, and restoring
         the work socket (60 panes) + personal (26 panes) at once spiked the load
         average. The sleep lets work's restore settle before personal piles on. -->
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>sleep 25; exec ./entrypoint.sh personal</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/hllvc/.repos/private/dotfiles/master/.shell/scripts/crons/tmux-warmup</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>TMUX_TMPDIR</key>
        <string>/Users/hllvc/.tmux/sockets</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/hllvc/Library/Logs/com.hllvc.tmux-warmup/out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/hllvc/Library/Logs/com.hllvc.tmux-warmup/err.log</string>
</dict>
</plist>
