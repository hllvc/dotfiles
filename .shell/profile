## general
export GOPATH="$HOME/go"

export PATH="$HOME/.local/bin:${KREW_ROOT:-$HOME/.krew}/bin:$GOPATH/bin:$HOME/.jenv/bin:$HOME/.local/share/gem/ruby/3.0.0/bin:$HOME/.cargo/bin:$PATH"

## jira cli
# export JIRA_API_TOKEN="op://"

## gemini-cli
export GEMINI_API_KEY="op://Personal/Gemini API Key/credential"

# history
export HISTSIZE=10000
export SAVEHIST=$HISTSIZE

# other
export FZF_DEFAULT_OPTS='--bind=ctrl-l:select,ctrl-h:deselect,ctrl-space:select-all,ctrl-n:clear-query,ctrl-u:preview-up,ctrl-d:preview-down'

export LANG=en_US.UTF-8
export EDITOR='nvim'

# zvm (nvim) in zsh
export KEYTIMEOUT=1

export NVM_DIR="$HOME/.nvm"

export BAT_THEME="gruvbox-dark"

export HOMEBREW_NO_AUTO_UPDATE=1
export SCRIPTS_DIRECTORY="$HOME/.shell/scripts"

## git
export GIT_ASKPASS="$HOME/.shell/scripts/unloaded/git-askpass.sh"
